// Base build settings for CodingReviewer
SWIFT_STRICT_CONCURRENCY = complete

// 2026 Platform Standards
COMPILATION_CACHING_ENABLE = YES
EXPERIMENTAL_SWIFT_EXPLICIT_MODULE_BUILDS = YES
OTHER_SWIFT_FLAGS = $(inherited) -Xfrontend -debug-time-function-bodies -show-build-timing-summary
// Project-specific overrides below
PRODUCT_BUNDLE_IDENTIFIER = com.DanielStevens.CodingReviewer
